# Copy to `.env` for local dev: `cp .env.example .env`. The values below are
# safe defaults for `docker compose up`. Replace anything marked "change-me"
# before deploying anywhere shared.

# ----- Database / cache -----
# These point at the services defined in docker-compose.yml. From outside the
# compose network (e.g. running a script on the host), substitute `localhost`
# for the service names.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/app  # pragma: allowlist secret
REDIS_URL=redis://redis:6379/0

# ----- JWT (used from Stage 1 onward) -----
# Generate a real secret with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-please-32-bytes-minimum-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=60
REFRESH_TOKEN_TTL_DAYS=30

# ----- Envelope encryption (used from Stage 6 onward) -----
# Master key-encryption-key. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
ENCRYPTION_KEK=dev-only-kek-replace-in-production-please-32b

# ----- CORS -----
# Comma-separated list of origins the API will accept browser requests from.
CORS_ORIGINS=http://localhost:3300

# ----- Frontend -----
# Public API base URL the browser uses. Must be reachable from the user's
# browser, not from inside the docker network.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8088
